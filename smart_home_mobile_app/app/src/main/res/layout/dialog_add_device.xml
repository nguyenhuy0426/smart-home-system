<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Thêm thiết bị"
        android:textColor="@color/sh_text_primary"
        android:textSize="18sp" />

    <!-- Chọn phòng để gán thiết bị -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Phòng"
        android:textColor="@color/sh_text_secondary"
        android:textSize="13sp" />

    <Spinner
        android:id="@+id/spinner_device_room"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_pill"
        android:padding="12dp" />

    <!-- Loại thiết bị -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Loại thiết bị"
        android:textColor="@color/sh_text_secondary"
        android:textSize="13sp" />

    <Spinner
        android:id="@+id/spinner_device_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_pill"
        android:padding="12dp" />
    <!-- Gợi ý các loại: Đèn, Quạt, Điều hoà, Khoá cửa vân tay/thẻ từ,
         Cảm biến nhiệt độ, Cảm biến độ ẩm, Cảm biến khói, Cảm biến bụi mịn PM2.5, Camera -->

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Tên thiết bị"
        app:boxBackgroundColor="@color/sh_card_alt"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusTopStart="14dp"
        app:boxStrokeColor="@color/sh_accent"
        app:hintTextColor="@color/sh_text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sh_text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel_device"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Huỷ"
            android:textColor="@color/sh_text_primary" />

        <TextView
            android:id="@+id/btn_save_device"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_selected"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Lưu thiết bị"
            android:textColor="@color/sh_bg" />
    </LinearLayout>

</LinearLayout>