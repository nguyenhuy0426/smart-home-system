<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_pill"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/sh_text_primary"
                tools:ignore="MissingPrefix" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Quản lý nhà"
                android:textColor="@color/sh_text_primary"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_home"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="@color/sh_card_alt"
                android:text="Tạo nhà"
                android:textColor="@color/sh_text_primary"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_join_home"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:backgroundTint="@color/sh_accent"
                android:text="Tham gia nhà"
                android:textColor="@color/sh_bg"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_invite"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="Tạo mã mời cho nhà đang chọn"
            android:textColor="@color/sh_accent"
            app:cornerRadius="24dp"
            app:strokeColor="@color/sh_accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_home"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Xóa nhà đang chọn"
            android:textColor="@android:color/holo_red_light"
            app:cornerRadius="24dp"
            app:strokeColor="@android:color/holo_red_light" />

        <TextView
            android:id="@+id/tv_empty_homes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center"
            android:padding="22dp"
            android:text="Chưa có nhà nào. Dùng mã mời từ quản trị viên để tham gia."
            android:textColor="@color/sh_text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_homes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_home_card" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
