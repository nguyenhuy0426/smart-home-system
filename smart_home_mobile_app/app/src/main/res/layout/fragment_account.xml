<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_pill"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/sh_text_primary"
                tools:ignore="MissingPrefix" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Tài khoản"
                android:textColor="@color/sh_text_primary"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_rounded"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/bg_pill_selected"
                android:padding="16dp"
                android:src="@drawable/ic_person"
                app:tint="@color/sh_bg"
                tools:ignore="MissingPrefix" />

            <TextView
                android:id="@+id/tv_account_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/sh_text_primary"
                android:textSize="18sp"
                tools:text="user@example.com" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_manage_homes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_pill"
                android:padding="10dp"
                android:src="@drawable/ic_tab_home"
                app:tint="@color/sh_accent"
                tools:ignore="MissingPrefix" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Quản lý nhà"
                    android:textColor="@color/sh_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Danh sách nhà, thêm nhà và tham gia bằng mã"
                    android:textColor="@color/sh_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/sh_accent"
                android:textSize="22sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="Đăng xuất"
            android:textColor="@color/sh_danger"
            app:strokeColor="@color/sh_danger" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
