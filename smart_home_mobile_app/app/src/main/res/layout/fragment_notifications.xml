<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg"
    android:clipToPadding="false"
    android:paddingBottom="110dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Thông báo"
            android:textColor="@color/sh_text_primary"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/tv_notifications_home_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/sh_text_secondary"
            android:textSize="13sp"
            tools:text="Nhà của Huy • 4 thông báo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_pill"
            android:padding="12dp"
            android:text="Ngưỡng mặc định: nhiệt độ 10–35°C, độ ẩm 30–80%, khói 50 ppm, PM2.5 35 µg/m³"
            android:textColor="@color/sh_text_secondary"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            tools:itemCount="4"
            tools:listitem="@layout/item_notification" />

        <TextView
            android:id="@+id/tv_notifications_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center"
            android:padding="24dp"
            android:text="Chưa có lịch sử điều khiển hoặc cảnh báo cảm biến"
            android:textColor="@color/sh_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
