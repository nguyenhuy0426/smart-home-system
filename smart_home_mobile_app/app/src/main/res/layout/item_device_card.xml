<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_rounded"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/img_device_photo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_pill"
        android:padding="8dp"
        android:src="@drawable/ic_bulb"
        app:tint="@color/sh_accent"
        tools:ignore="MissingPrefix" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="Đèn thông minh"
            android:textColor="@color/sh_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_device_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Đang tắt"
            android:textColor="@color/sh_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_delete_device"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_pill"
        android:contentDescription="Xóa thiết bị"
        android:padding="9dp"
        android:src="@drawable/ic_delete"
        app:tint="@color/sh_danger"
        tools:ignore="MissingPrefix" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_device_power"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:thumbTint="@color/sh_accent"
        app:trackTint="@color/sh_track_off" />
</LinearLayout>
