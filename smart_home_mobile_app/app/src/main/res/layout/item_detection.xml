<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_rounded"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Ảnh chụp nhỏ tại thời điểm phát hiện -->
    <ImageView
        android:id="@+id/img_event_thumb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_pill"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_camera_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Loại sự kiện, ví dụ "Phát hiện té ngã" / "Phát hiện người lạ" -->
        <TextView
            android:id="@+id/tv_event_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phát hiện té ngã"
            android:textColor="@color/sh_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_event_location_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Phòng khách • 14:32, 08/07"
            android:textColor="@color/sh_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Mức độ khẩn cấp -->
    <TextView
        android:id="@+id/tv_event_severity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="Khẩn cấp"
        android:textColor="@color/sh_danger"
        android:textSize="11sp" />

</LinearLayout>