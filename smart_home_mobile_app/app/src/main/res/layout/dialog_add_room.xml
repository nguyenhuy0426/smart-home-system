<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/sh_bg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <!-- Tay cầm kéo bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_pill"
        android:backgroundTint="@color/sh_text_secondary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm phòng mới"
        android:textColor="@color/sh_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_room_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Tên phòng (ví dụ: Phòng ngủ)"
        app:boxStrokeColor="@color/sh_accent"
        app:hintTextColor="@color/sh_text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_room_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:textColor="@color/sh_text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_room_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tên phòng không được để trống"
        android:textColor="@color/sh_danger"
        android:textSize="13sp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_room"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/sh_accent"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="Thêm phòng"
        android:textColor="@color/sh_bg"
        android:textStyle="bold"
        app:cornerRadius="14dp" />
</LinearLayout>