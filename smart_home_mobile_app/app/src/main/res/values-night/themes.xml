<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night mode intentionally reuses the same light palette to match the former
         Compose TuyaTheme, which never switched to a dark scheme. -->
    <style name="Base.Theme.Smart_home_mobile_app" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/sh_accent</item>
        <item name="colorOnPrimary">@color/sh_bg</item>
        <item name="colorSecondary">@color/sh_accent_soft</item>
        <item name="colorOnSecondary">@color/sh_text_primary</item>
        <item name="android:colorBackground">@color/sh_bg</item>
        <item name="colorSurface">@color/sh_card</item>
        <item name="colorOnSurface">@color/sh_text_primary</item>
        <item name="colorSurfaceVariant">@color/sh_card_alt</item>
        <item name="colorOnSurfaceVariant">@color/sh_text_secondary</item>
        <item name="colorError">@color/sh_danger</item>
    </style>
</resources>
