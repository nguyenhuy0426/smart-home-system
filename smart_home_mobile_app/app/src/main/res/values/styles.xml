<resources>

    <style name="LoginGlassTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#52141210</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/login_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">#A99A8E</item>
        <item name="android:textColorHint">#A99A8E</item>
    </style>

    <style name="LoginOutlineButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/login_glass_button_text</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/login_glass_button_tint</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">8dp</item>
        <item name="rippleColor">#44FFFFFF</item>
        <item name="strokeColor">@color/login_glass_button_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="LoginGlassPrimaryButton" parent="LoginOutlineButton">
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">12dp</item>
    </style>

    <style name="LoginOutlineButton.Compact">
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">24dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="ShapeAppearance.SmartHome.BottomNavPill" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="BottomNavLiquidActiveIndicator">
        <item name="android:width">84dp</item>
        <item name="android:height">42dp</item>
        <item name="android:color">#F6F2EA</item>
        <item name="shapeAppearance">@style/ShapeAppearance.SmartHome.BottomNavPill</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.SmartHome.BottomNavPill</item>
    </style>

    <style name="BottomNavLiquidText.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">0sp</item>
    </style>

    <style name="BottomNavLiquidText.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">0sp</item>
    </style>
</resources>
