<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg">

    <FrameLayout
        android:id="@+id/nav_host"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/sh_bg" />

    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_gravity="bottom"
        android:clipToPadding="false"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_gravity="bottom|center_horizontal"
            android:background="@drawable/bg_bottom_nav_glass"
            android:elevation="10dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:elevation="10dp"
            app:itemActiveIndicatorStyle="@style/BottomNavLiquidActiveIndicator"
            app:itemIconSize="22dp"
            app:itemIconTint="@color/bottom_nav_item_color"
            app:itemPaddingBottom="0dp"
            app:itemPaddingTop="0dp"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextAppearanceActive="@style/BottomNavLiquidText.Active"
            app:itemTextAppearanceInactive="@style/BottomNavLiquidText.Inactive"
            app:itemTextColor="@color/bottom_nav_item_color"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</FrameLayout>
