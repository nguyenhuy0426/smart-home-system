<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:orientation="horizontal"
    android:padding="18dp">

    <!-- Icon khoá cửa -->
    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_icon_circle">

        <ImageView
            android:id="@+id/img_door_icon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            app:tint="@color/sh_accent"
            tools:ignore="MissingPrefix" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_door_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Cửa chính"
            android:textColor="@color/sh_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_door_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Đã khoá • Vân tay xác thực lúc 07:42"
            android:textColor="@color/sh_text_secondary"
            android:textSize="12sp" />

        <!-- Hai badge nhỏ: trạng thái vân tay / thẻ từ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_fingerprint_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:drawablePadding="4dp"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Vân tay: OK"
                android:textColor="@color/sh_success"
                android:textSize="11sp"
                app:drawableStartCompat="@drawable/ic_fingerprint"
                tools:ignore="MissingPrefix" />

            <TextView
                android:id="@+id/tv_card_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill"
                android:drawablePadding="4dp"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Thẻ từ: OK"
                android:textColor="@color/sh_success"
                android:textSize="11sp"
                app:drawableStartCompat="@drawable/ic_card"
                tools:ignore="MissingPrefix" />
        </LinearLayout>
    </LinearLayout>

    <!-- Pin ổ khoá, ví dụ 92% như ảnh mẫu -->
    <TextView
        android:id="@+id/tv_door_battery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:fontFamily="sans-serif-medium"
        android:text="92%"
        android:textColor="@color/sh_accent"
        android:textSize="16sp" />

</LinearLayout>