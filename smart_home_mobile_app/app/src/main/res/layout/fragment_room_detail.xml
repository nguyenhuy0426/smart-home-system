<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg"
    android:clipToPadding="false"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_room_detail_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_pill"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/sh_text_primary"
                tools:ignore="MissingPrefix" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_room_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:textColor="@color/sh_text_primary"
                    android:textSize="24sp"
                    tools:text="Phòng khách" />

                <TextView
                    android:id="@+id/tv_room_detail_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/sh_text_secondary"
                    android:textSize="12sp"
                    tools:text="Nhà của Huy" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_room_camera_panel"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_pill_selected"
                    android:backgroundTint="@color/sh_danger" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="GIÁM SÁT"
                    android:textColor="@color/sh_text_primary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_room_camera_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/sh_text_primary"
                    android:textSize="20sp"
                    tools:text="Camera giám sát" />

                <TextView
                    android:id="@+id/tv_room_camera_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/sh_text_secondary"
                    android:textSize="13sp"
                    tools:text="Chưa có camera trong phòng này" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Điều khiển thiết bị"
                android:textColor="@color/sh_text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_room_detail_device_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/sh_text_secondary"
                android:textSize="13sp"
                tools:text="2 thiết bị" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_room_detail_devices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            tools:listitem="@layout/item_device_card" />

        <TextView
            android:id="@+id/layout_room_devices_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center"
            android:padding="24dp"
            android:text="Phòng này chưa có thiết bị để điều khiển"
            android:textColor="@color/sh_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
