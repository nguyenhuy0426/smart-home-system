<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sh_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_pill"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/sh_text_primary"
                tools:ignore="MissingPrefix" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Tạo nhà mới"
                android:textColor="@color/sh_text_primary"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_rounded"
            android:orientation="vertical"
            android:padding="18dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="Tên nhà"
                app:boxStrokeColor="@color/sh_accent"
                app:hintTextColor="@color/sh_text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_home_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:textColor="@color/sh_text_primary"
                    tools:text="Nhà của Huy" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Loại nhà"
                app:boxStrokeColor="@color/sh_accent"
                app:hintTextColor="@color/sh_text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_home_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:text="Nhà riêng"
                    android:textColor="@color/sh_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Địa chỉ (không bắt buộc)"
                app:boxStrokeColor="@color/sh_accent"
                app:hintTextColor="@color/sh_text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_home_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:maxLines="2"
                    android:textColor="@color/sh_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_create_home_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sh_danger"
                android:textSize="13sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_home_submit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/sh_accent"
                android:text="Tạo nhà"
                android:textColor="@color/sh_bg"
                android:textStyle="bold"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
